{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Derived from the OpenAI Codex review-output schema (Copyright 2026 OpenAI, Apache-2.0) and extended: category, exploit_scenario, evidence, coverage, and file-level findings (line_start/line_end = 0). See NOTICE and LICENSE.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "coverage",
    "findings",
    "next_steps"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "approve",
        "needs-attention"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_examined",
        "files_skipped"
      ],
      "properties": {
        "files_examined": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_skipped": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "category",
          "title",
          "body",
          "exploit_scenario",
          "evidence",
          "file",
          "line_start",
          "line_end",
          "confidence",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "category": {
            "type": "string",
            "enum": [
              "correctness",
              "security",
              "auth",
              "injection",
              "secrets",
              "data-loss",
              "rollback",
              "concurrency",
              "compatibility",
              "observability",
              "resource-exhaustion",
              "supply-chain",
              "ci-cd",
              "test-integrity",
              "error-handling",
              "privacy",
              "performance",
              "other"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "exploit_scenario": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line_start": {
            "type": "integer",
            "minimum": 0
          },
          "line_end": {
            "type": "integer",
            "minimum": 0
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "corroborated_by": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
